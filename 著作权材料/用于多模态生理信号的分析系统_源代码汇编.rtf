\pard\ql\li360\sa0\sb0\f2\fs16 def test_heartrate_analysis_detects_beats_from_noisy_inverted_ecg():\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~fs = 250\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~beat_times = np.arange(1.0, 9.1, 1.0)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~ecg_signal = _make_noisy_ecg(fs, duration_seconds=10, beat_times=beat_times)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~config = \{\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~"datainfo": \{\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~"Fs": fs,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~"segment_labels": ["ecg_segment_1"],\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\},\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~"display": \{\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~"heart_rate_show": False,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\},\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\}\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~result = heartrate_analysis([ecg_signal], config)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~assert result["segments"][0]["detected"] is True\par
