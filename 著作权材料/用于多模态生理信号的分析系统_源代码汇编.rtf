\pard\ql\sb180\sa80\sl360\slmult1\f0\fs24\b 8. utils/Heartrate.py\par
\pard\ql\li360\sa0\sb0\f2\fs16 """Heart-rate and HRV analysis helpers."""\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 import matplotlib.pyplot as plt\par
\pard\ql\li360\sa0\sb0\f2\fs16 import matplotlib.ticker as ticker\par
\pard\ql\li360\sa0\sb0\f2\fs16 import numpy as np\par
\pard\ql\li360\sa0\sb0\f2\fs16 from scipy.signal import find_peaks\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 from utils.ui import add_series, as_bool, finish_figure, make_plot_title, print_kv, print_status, print_subsection, print_success, style_axes\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 def _robust_scale(values):\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~"""Scale a signal using MAD first and standard deviation as fallback."""\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~centered = values - np.median(values)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~mad = np.median(np.abs(centered))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~if mad > 1e-9:\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~return centered / (1.4826 * mad)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~std = np.std(centered)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~if std > 1e-9:\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~return centered / std\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~return centered\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 def _smooth_signal(values, fs):\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~"""Apply a short moving average to reduce isolated spikes before peak picking."""\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~window = max(1, int(round(fs * 0.08)))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~if window <= 1:\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~return values\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~kernel = np.ones(window, dtype=float) / window\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~return np.convolve(values, kernel, mode="same")\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 def _prune_artifact_peaks(peaks, enhanced, fs):\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~"""Remove isolated weak peaks that split one normal beat into two short RR intervals."""\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~peaks = np.asarray(peaks, dtype=int)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~if len(peaks) < 3:\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~return peaks\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~enhanced = np.asarray(enhanced, dtype=float)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~changed = True\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~while changed and len(peaks) >= 3:\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~changed = False\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~rr = np.diff(peaks) / fs\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~if len(rr) < 2:\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~break\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~median_rr = float(np.median(rr))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~short_rr_limit = min(0.55, 0.72 * median_rr)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~for idx in range(1, len(peaks) - 1):\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~prev_rr = (peaks[idx] - peaks[idx - 1]) / fs\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~next_rr = (peaks[idx + 1] - peaks[idx]) / fs\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~combined_rr = prev_rr + next_rr\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~peak_height = float(enhanced[peaks[idx]])\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~neighbor_height = float(np.median([enhanced[peaks[idx - 1]], enhanced[peaks[idx + 1]]]))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~is_isolated_short_rr = min(prev_rr, next_rr) < short_rr_limit\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~looks_like_split_beat = abs(combined_rr - median_rr) <= 0.28 * median_rr\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~is_weaker_peak = peak_height < 0.72 * neighbor_height\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~if is_isolated_short_rr and looks_like_split_beat and is_weaker_peak:\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~peaks = np.delete(peaks, idx)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~changed = True\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~break\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~return peaks\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 def _detect_r_peaks(signal, fs):\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~"""Detect ECG R-peaks using adaptive polarity and two-stage thresholds."""\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~normalized = _robust_scale(np.asarray(signal, dtype=float))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~positive_tail = np.percentile(normalized, 95)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~negative_tail = abs(np.percentile(normalized, 5))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~if negative_tail > positive_tail:\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~normalized = -normalized\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~enhanced = _smooth_signal(normalized, fs)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~min_distance = max(1, int(round(fs * 0.35)))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~spread = max(np.std(enhanced), 1e-6)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~peaks, _ = find_peaks(\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~enhanced,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~distance=min_distance,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~height=max(0.6, float(np.percentile(enhanced, 75))),\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~prominence=max(0.5, 0.3 * spread),\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~if len(peaks) > 1:\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~return _prune_artifact_peaks(peaks, enhanced, fs)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~peaks, _ = find_peaks(\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~enhanced,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~distance=min_distance,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~height=max(0.3, float(np.percentile(enhanced, 65))),\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~prominence=max(0.3, 0.2 * spread),\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~return _prune_artifact_peaks(peaks, enhanced, fs)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 def heartrate_analysis(dataset, config):\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~"""Compute RR intervals, heart rate, and HRV metrics for each ECG segment."""\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~fs = float(config["datainfo"]["Fs"])\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~display_config = config.get("display", \{\})\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~output_config = config.get("output", \{\})\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~show = as_bool(display_config.get("heart_rate_show", False))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~save_figures = as_bool(output_config.get("save_figures", False))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~segment_labels = config["datainfo"].get("segment_labels", [])\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~print_subsection("Heart Rate")\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~print_status("Detecting R-peaks and computing HRV metrics.")\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~results = []\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~for idx, arr in enumerate(dataset):\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~label = segment_labels[idx] if idx < len(segment_labels) else f"segment_\{idx + 1\}"\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~peaks = _detect_r_peaks(arr, fs)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~if len(peaks) <= 1:\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~print_status(f"\{label\}: not enough R-peaks detected.")\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~results.append(\{"label": label, "detected": False\})\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~continue\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~rr_intervals = np.diff(peaks) / fs\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~rr_ms = rr_intervals * 1000\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~heart_rate = 60 / rr_intervals\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~time_hr = peaks[1:] / fs\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~sdnn = float(np.std(rr_ms))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~rmssd = float(np.sqrt(np.mean(np.diff(rr_ms) ** 2))) if len(rr_ms) > 1 else 0.0\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~print_kv(f"\{label\} SDNN", f"\{sdnn:.2f\} ms")\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~print_kv(f"\{label\} RMSSD", f"\{rmssd:.2f\} ms")\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~if show or save_figures:\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~# TODO: Visualization styling lives here so it can be tuned globally later.\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~fig, ax = plt.subplots(figsize=(10.5, 4.5))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~add_series(ax, time_hr, heart_rate, color="#a63446", linewidth=2.0, fill=True)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~style_axes(ax, make_plot_title(config, label, "Heart Rate"), "Time (s)", "Heart Rate (bpm)")\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~ax.yaxis.set_major_locator(ticker.MaxNLocator(integer=True))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~finish_figure(\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~fig,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~config=config,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~module_name="heart_rate",\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~label=label,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~figure_name="trend",\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~show=show,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~results.append(\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\{\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~"label": label,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~"detected": True,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~"rr_intervals_ms": rr_ms,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~"sdnn_ms": sdnn,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~"rmssd_ms": rmssd,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~"heart_rate_bpm": heart_rate,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~"time_s": time_hr,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\}\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~print_success("Heart-rate analysis finished.")\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~return \{"segments": results\}\par
\pard\sa120\par
\pard\ql\sb180\sa80\sl360\slmult1\f0\fs24\b 9. utils/LoadDataset.py\par
\pard\ql\li360\sa0\sb0\f2\fs16 """Dataset loading and normalization helpers."""\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 import os\par
\pard\ql\li360\sa0\sb0\f2\fs16 from datetime import datetime, time\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 import numpy as np\par
\pard\ql\li360\sa0\sb0\f2\fs16 import pandas as pd\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 from nm_config import infer_signal_modality\par
\pard\ql\li360\sa0\sb0\f2\fs16 from utils.ui import print_kv, print_section, print_status, print_subsection, print_success\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 def _format_datetime(value):\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~"""Format datetimes with millisecond precision for console output."""\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~return value.strftime("%Y-%m-%d %H:%M:%S.%f")[:-3]\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 def _parse_slice_boundary(value):\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~"""Parse either a time-only boundary or a full datetime boundary."""\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~if value in (None, ""):\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~return None\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~if isinstance(value, time):\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~return ("time", value)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~if isinstance(value, datetime):\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~return ("datetime", value)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~text = str(value).strip()\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~try:\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~return ("datetime", datetime.fromisoformat(text))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~except ValueError:\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~return ("time", time.fromisoformat(text))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 def _build_time_mask(datetime_objects, slice_start, slice_end):\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~"""Build a boolean mask for the requested time window."""\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~if slice_start is None and slice_end is None:\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~return np.ones(len(datetime_objects), dtype=bool)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~start_kind = _parse_slice_boundary(slice_start)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~end_kind = _parse_slice_boundary(slice_end)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~if start_kind is None or end_kind is None:\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~raise ValueError("When slice_enabled is True, both slice_start and slice_end must be set.")\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~if start_kind[0] != end_kind[0]:\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~raise ValueError("slice_start and slice_end must use the same time format.")\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~if start_kind[0] == "datetime":\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~start_value, end_value = start_kind[1], end_kind[1]\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~return np.array([start_value <= dt <= end_value for dt in datetime_objects], dtype=bool)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~start_value, end_value = start_kind[1], end_kind[1]\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~return np.array([start_value <= dt.time() <= end_value for dt in datetime_objects], dtype=bool)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 def _resolve_sampling_rate(config):\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~"""Resolve the final sampling rate using the original project scaling formula."""\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~raw_fs = float(config["dataset"].get("source_sampling_rate", 1000))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~scale = float(config["dataset"].get("sampling_rate_scale", 1.0))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~return max(1, round(raw_fs * scale))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 def _segment_signal(signal, fs, segment_seconds):\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~"""Split one 1D signal into equally sized analysis segments."""\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~if not segment_seconds or segment_seconds <= 0:\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~return [signal]\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~max_length = max(1, int(round(fs * segment_seconds)))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~if len(signal) <= max_length:\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~return [signal]\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~segment_count = int(np.ceil(len(signal) / max_length))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~return [segment for segment in np.array_split(signal, segment_count) if len(segment) > 0]\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 def _apply_channel_strategy(signals, channel_names, config):\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~"""Apply the modality-specific channel handling policy."""\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~strategy = config["datainfo"].get("channel_strategy", "single")\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~if strategy == "average_to_single":\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~averaged_signal = np.mean(np.vstack(signals), axis=0)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~averaged_name = f"\{config['datainfo']['signal_type']\}_mean"\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~return [averaged_signal], [averaged_name]\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~return signals, channel_names\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 def load_dataset(config):\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~"""Load headerless CSV recordings and normalize them into 1D segments."""\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~config.setdefault("datainfo", \{\})\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~file_dir = config["fileinfo"]["fullpath"]\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~file_type = config["fileinfo"]["filetype"]\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~if not os.path.isdir(file_dir):\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~raise FileNotFoundError(f"Data directory does not exist: \{file_dir\}")\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~file_list = [file_name for file_name in os.listdir(file_dir) if file_name.endswith(file_type)]\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~if config["dataset"].get("sort_files", True):\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~file_list.sort()\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~if not file_list:\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~raise FileNotFoundError(f"No \{file_type\} files were found in \{file_dir\}.")\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~timestamp_column = int(config["dataset"].get("timestamp_column", 0))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~signal_column = int(config["dataset"].get("signal_column", 2))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~raw_signals = []\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~raw_timestamps = []\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~channel_names = []\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~for file_name in file_list:\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~full_path = os.path.join(file_dir, file_name)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~frame = pd.read_csv(full_path, header=None)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~if frame.shape[1] <= max(timestamp_column, signal_column):\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~raise ValueError(\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~f"\{file_name\} is missing an expected column. Only \{frame.shape[1]\} columns were found."\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~raw_timestamps.append(frame.iloc[:, timestamp_column].to_numpy(dtype=np.int64))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~raw_signals.append(frame.iloc[:, signal_column].to_numpy(dtype=float))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~channel_names.append(os.path.splitext(file_name)[0])\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~modality, profile = infer_signal_modality(file_dir, channel_names)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~config["datainfo"]["signal_type"] = modality\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~config["datainfo"]["signal_display_name"] = profile["display_name"]\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~config["datainfo"]["channel_strategy"] = profile["channel_strategy"]\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~config["analysis"]["enabled_modules"] = list(profile["analysis_modules"])\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~config["preprocess"]["bpfreq"] = list(profile["bandpass"])\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~config["preprocess"]["bsfreq"] = list(profile["bandstop"])\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~# Truncate every channel to the shortest one to preserve alignment before averaging.\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~min_len = min(len(signal) for signal in raw_signals)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~raw_signals = [signal[:min_len] for signal in raw_signals]\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~raw_timestamps = [timestamps[:min_len] for timestamps in raw_timestamps]\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~reference_timestamps = raw_timestamps[0]\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~datetime_objects = np.array(\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~[datetime.fromtimestamp(timestamp / 1000.0) for timestamp in reference_timestamps],\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~dtype=object,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~experiment_start = datetime_objects[0]\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~experiment_end = datetime_objects[-1]\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~print_section("LOAD DATASET")\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~print_subsection("Experiment Window")\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~print_kv("Start time", _format_datetime(experiment_start))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~print_kv("End time", _format_datetime(experiment_end))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~print_kv("Duration", experiment_end - experiment_start)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~if config["dataset"].get("slice_enabled", False):\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~time_mask = _build_time_mask(\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~datetime_objects,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~config["dataset"].get("slice_start"),\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~config["dataset"].get("slice_end"),\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~if not np.any(time_mask):\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~raise ValueError("The selected slice window did not match any samples.")\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~raw_signals = [signal[time_mask] for signal in raw_signals]\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~datetime_objects = datetime_objects[time_mask]\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~reference_timestamps = reference_timestamps[time_mask]\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~print_subsection("Slice Window")\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~print_kv("Slice start", _format_datetime(datetime_objects[0]))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~print_kv("Slice end", _format_datetime(datetime_objects[-1]))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~print_kv("Slice samples", len(datetime_objects))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~processed_channels, processed_names = _apply_channel_strategy(raw_signals, channel_names, config)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~resolved_fs = _resolve_sampling_rate(config)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~segment_seconds = config["dataset"].get("segment_duration_seconds", 60)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~dataset = []\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~segment_labels = []\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~for channel_name, signal in zip(processed_names, processed_channels):\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~for segment_idx, segment in enumerate(_segment_signal(signal, resolved_fs, segment_seconds), start=1):\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~dataset.append(np.asarray(segment, dtype=float))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~segment_labels.append(f"\{channel_name\}_segment_\{segment_idx\}")\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~config["datainfo"]["Fs"] = resolved_fs\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~config["datainfo"]["chcnt"] = len(processed_channels)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~config["datainfo"]["chname"] = processed_names\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~config["datainfo"]["source_channels"] = channel_names\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~config["datainfo"]["segment_count"] = len(dataset)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~config["datainfo"]["segment_labels"] = segment_labels\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~config["datainfo"]["time_range"] = \{\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~"experiment_start": _format_datetime(experiment_start),\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~"experiment_end": _format_datetime(experiment_end),\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~"slice_start": _format_datetime(datetime_objects[0]),\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~"slice_end": _format_datetime(datetime_objects[-1]),\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~"sample_count": len(datetime_objects),\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~"timestamps_ms": \{\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~"start": int(reference_timestamps[0]),\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~"end": int(reference_timestamps[-1]),\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\},\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\}\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~print_subsection("Resolved Profile")\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~print_kv("Signal modality", f"\{config['datainfo']['signal_display_name']\} (\{modality\})")\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~print_kv("Source channels", ", ".join(channel_names))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~print_kv("Analysis channels", ", ".join(processed_names))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~print_kv("Band-pass", config["preprocess"]["bpfreq"])\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~print_kv("Sampling rate", f"\{config['datainfo']['Fs']:.4f\} Hz")\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~print_kv("Segment count", len(dataset))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~print_kv("Segment labels", ", ".join(segment_labels))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~print_status("Dataset loading finished.")\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~print_success()\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~return dataset, config\par
