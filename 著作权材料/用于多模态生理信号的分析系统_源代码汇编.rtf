\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~"save_figures": False,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~"figure_format": "png",\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~"figure_dpi": 320,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~"organize_by_modality": True,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~"save_band_metrics_csv": False,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\}\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 def _build_dataset_config():\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~"""Return dataset loading, slicing, and segmentation defaults."""\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~return \{\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~"source_sampling_rate": 1000,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~"timestamp_column": 0,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~"signal_column": 2,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~"sort_files": True,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~"slice_enabled": False,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~"slice_start": None,  # Example: "17:17:10" or "2024-06-26 17:17:10"\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~"slice_end": None,  # Example: "17:19:30" or "2024-06-26 17:19:30"\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~"segment_duration_seconds": 60,\par
