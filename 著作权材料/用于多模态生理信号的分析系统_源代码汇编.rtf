\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~"beta_low": "#4c956c",\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~"beta_high": "#c98c1d",\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~"gamma": "#a63446",\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\}\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~segment_results = []\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~for idx, signal in enumerate(dataset):\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~label = segment_labels[idx] if idx < len(segment_labels) else f"segment_\{idx + 1\}"\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~signal = np.asarray(signal, dtype=float)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~nfft = 2 ** int(np.ceil(np.log2(win_len)))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~freqs, times, spectrum = spectrogram(\par
