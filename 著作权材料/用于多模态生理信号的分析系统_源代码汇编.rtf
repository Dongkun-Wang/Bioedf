\pard\ql\li360\sa0\sb0\f2\fs16 def test_detect_r_peaks_ignores_weaker_midcycle_artifacts():\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~fs = 250\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~time_axis = np.arange(0, 10, 1 / fs)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~beat_times = np.arange(1.0, 9.1, 1.0)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~signal = np.zeros_like(time_axis)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~for beat_time in beat_times:\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~signal += 2.4 * np.exp(-0.5 * ((time_axis - beat_time) / 0.018) ** 2)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~# Add a weaker broad bump that should not be counted as another R-peak.\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~signal += 0.75 * np.exp(-0.5 * ((time_axis - (beat_time + 0.34)) / 0.05) ** 2)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~peaks = _detect_r_peaks(signal, fs)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~assert len(peaks) == len(beat_times)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~detected_times = peaks / fs\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~assert np.allclose(detected_times, beat_times, atol=0.05)\par
\pard\sa120\par
