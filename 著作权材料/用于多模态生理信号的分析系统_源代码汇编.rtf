\pard\ql\li360\sa0\sb0\f2\fs16 import numpy as np\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 from utils.Heartrate import _detect_r_peaks, heartrate_analysis\par
