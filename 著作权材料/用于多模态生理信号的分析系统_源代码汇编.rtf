\pard\ql\li360\sa0\sb0\f2\fs16 """Configuration defaults and signal-modality inference helpers."""\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 import os\par
\pard\ql\li360\sa0\sb0\f2\fs16 from pathlib import Path\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 DATASET_DIRECTORY_ALIASES = \{\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~# Keep English aliases and legacy Chinese directory names for compatibility.\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~"eeg": ("eeg", "\\u8111\\u7535"),\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~"ecg": ("ecg", "ekg", "\\u5fc3\\u7535"),\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~"emg": ("emg", "leg", "arm", "\\u53f3\\u817f", "\\u5de6\\u817f", "\\u808c\\u7535", "\\u5de6\\u81c2"),\par
\pard\ql\li360\sa0\sb0\f2\fs16 \}\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 SIGNAL_PROFILES = \{\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~"eeg": \{\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~"display_name": "EEG",\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~"keywords": DATASET_DIRECTORY_ALIASES["eeg"],\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~"bandpass": [1, 60],\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~"bandstop": [48, 52],\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~"channel_strategy": "average_to_single",\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~"analysis_modules": ["band"],\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\},\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~"ecg": \{\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~"display_name": "ECG",\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~"keywords": DATASET_DIRECTORY_ALIASES["ecg"],\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~"bandpass": [1, 10],\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~"bandstop": [48, 52],\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~"channel_strategy": "single",\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~"analysis_modules": ["heart_rate"],\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\},\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~"emg": \{\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~"display_name": "EMG",\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~"keywords": DATASET_DIRECTORY_ALIASES["emg"] + ("bicep", "tricep"),\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~"bandpass": [1, 250],\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~"bandstop": [48, 52],\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~"channel_strategy": "single",\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~"analysis_modules": ["fft", "stft", "freq_analysis"],\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\},\par
\pard\ql\li360\sa0\sb0\f2\fs16 \}\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 def infer_signal_modality(file_dir, file_names):\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~"""Infer EEG, ECG, or EMG from directory and file naming patterns."""\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~text_parts = [file_dir, os.path.basename(file_dir)] + list(file_names)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~searchable = " ".join(part.lower() for part in text_parts if part)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~for modality, profile in SIGNAL_PROFILES.items():\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~if any(keyword.lower() in searchable for keyword in profile["keywords"]):\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~return modality, profile\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~if len(file_names) >= 4:\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~return "eeg", SIGNAL_PROFILES["eeg"]\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~raise ValueError(f"Unable to infer signal modality from directory name: \{file_dir\}")\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 def _build_fileinfo(result_dir):\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~"""Return file and export location defaults."""\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~return \{\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~"fullpath": "",\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~"filetype": ".csv",\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~"result_dir": str(result_dir),\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\}\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 def _build_output_config():\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~"""Return figure and table export defaults."""\par
