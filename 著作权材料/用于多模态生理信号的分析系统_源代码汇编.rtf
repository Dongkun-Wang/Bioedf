\pard\ql\li360\sa0\sb0\f2\fs16 def humanize_text(value):\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~"""Convert identifiers to reader-friendly labels."""\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~text = str(value).replace("_", " ").strip()\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~return re.sub(r"\\s+", " ", text)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 def make_plot_title(config, label, title):\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~"""Build compact, publication-style figure titles."""\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~modality = config.get("datainfo", \{\}).get("signal_display_name", "Signal")\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~match = re.search(r"segment_(\\d+)", str(label))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~if match:\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~base = f"\{modality\} Segment \{int(match.group(1))\}"\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~else:\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~base = humanize_text(label)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~return f"\{base\} \{title\}".strip()\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 def _slugify_filename_part(value):\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~"""Convert arbitrary labels to filesystem-safe filename parts."""\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~text = re.sub(r"\\s+", "_", str(value).strip())\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~text = re.sub(r"[^\\w.\\-]+", "_", text, flags=re.UNICODE)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~return text.strip("._") or "figure"\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 def build_figure_path(config, module_name, label, *, data_title=None, figure_name=None):\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~"""Build a consistent figure output path from runtime config."""\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~root = Path(config["fileinfo"].get("result_dir", "./result"))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~if as_bool(config.get("output", \{\}).get("organize_by_modality", True)):\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~modality = config.get("datainfo", \{\}).get("signal_display_name") or config.get("datainfo", \{\}).get("signal_type", "misc")\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~root = root / _slugify_filename_part(str(modality).upper())\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~root = root / _slugify_filename_part(module_name)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~parts = [_slugify_filename_part(label)]\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~if data_title:\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~parts.append(_slugify_filename_part(data_title))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~if figure_name:\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~parts.append(_slugify_filename_part(figure_name))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~figure_format = config.get("output", \{\}).get("figure_format", "png")\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~return root / f"\{'_'.join(parts)\}.\{figure_format\}"\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 def finish_figure(\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~fig,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~*,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~config=None,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~module_name=None,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~label=None,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~data_title=None,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~figure_name=None,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~show=False,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~layout="tight",\par
\pard\ql\li360\sa0\sb0\f2\fs16 ):\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~"""Finalize, optionally save, show, and close a figure."""\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~if layout == "tight":\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~fig.tight_layout()\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~elif layout == "constrained":\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~fig.set_constrained_layout(True)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~save_path = None\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~if config is not None and as_bool(config.get("output", \{\}).get("save_figures", False)):\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~if not module_name or not label:\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~raise ValueError("module_name and label are required when save_figures is enabled.")\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~save_path = build_figure_path(\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~config,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~module_name,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~label,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~data_title=data_title,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~figure_name=figure_name,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~os.makedirs(save_path.parent, exist_ok=True)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~fig.savefig(\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~save_path,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~dpi=int(config.get("output", \{\}).get("figure_dpi", 300)),\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~facecolor=fig.get_facecolor(),\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~if show:\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~plt.show()\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~plt.close(fig)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~return str(save_path) if save_path else None\par
\pard\sa120\par
