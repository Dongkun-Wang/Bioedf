\pard\ql\li360\sa0\sb0\f2\fs16 def as_bool(value):\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~"""Coerce legacy on/off values and regular truthy values to bool."""\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~if isinstance(value, bool):\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~return value\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~if isinstance(value, str):\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~normalized = value.strip().lower()\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~if normalized in \{"on", "true", "yes", "1"\}:\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~return True\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~if normalized in \{"off", "false", "no", "0"\}:\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~return False\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~return bool(value)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
