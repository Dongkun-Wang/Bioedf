\pard\ql\li360\sa0\sb0\f2\fs16 """FFT-based spectrum analysis."""\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 import matplotlib.pyplot as plt\par
\pard\ql\li360\sa0\sb0\f2\fs16 import numpy as np\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 from utils.ui import add_series, as_bool, finish_figure, make_plot_title, print_status, print_subsection, print_success, style_axes\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 def run_fft(dataset, data_title, config):\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~"""Run FFT for every segment and optionally plot or save the spectrum."""\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~fs = float(config["datainfo"]["Fs"])\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~display_config = config.get("display", \{\})\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~output_config = config.get("output", \{\})\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~fftshow = as_bool(display_config.get("fft_show", False))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~ffttype = config["analysis"].get("fft_type", "log")\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~fftsave = as_bool(output_config.get("save_figures", False))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~segment_labels = config["datainfo"].get("segment_labels", [])\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~print_subsection("FFT")\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~print_status("Computing spectra.")\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~fft_results = []\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~for idx, signal in enumerate(dataset):\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~signal = np.asarray(signal, dtype=float)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~n_len = len(signal)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~ns = 2 ** int(np.floor(np.log2(n_len)))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~if ns == 0:\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~continue\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~# Use the largest power-of-two window from the tail for stable FFT sizing.\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~windowed_signal = signal[-ns:] * np.hanning(ns)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~windowed_fft = np.fft.rfft(windowed_signal)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~magnitude = np.abs(windowed_fft) / ns\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~power = magnitude**2\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~frequency = np.fft.rfftfreq(ns, d=1.0 / fs)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~label = segment_labels[idx] if idx < len(segment_labels) else f"segment_\{idx + 1\}"\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~fft_results.append(\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\{\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~"label": label,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~"frequency_hz": frequency,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~"magnitude": magnitude,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~"power": power,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\}\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~if fftshow or fftsave:\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~# TODO: Visualization styling lives here so it can be tuned globally later.\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~fig, ax = plt.subplots(figsize=(10.5, 4.5))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~if ffttype == "log":\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~plot_y = 10 * np.log10(power + 1e-12)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~ylabel = "Power (dB)"\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~else:\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~plot_y = power\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~ylabel = "Power"\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~high_cut = float(config["preprocess"].get("bpfreq", [0, fs / 2])[1])\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~ax.set_xlim(0, min(fs / 2, max(30.0, high_cut * 1.15)))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~add_series(ax, frequency, plot_y, color="#0f766e", linewidth=1.7)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~style_axes(ax, make_plot_title(config, label, "FFT Spectrum"), "Frequency (Hz)", ylabel)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~finish_figure(\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~fig,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~config=config,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~module_name="fft",\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~label=label,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~data_title=data_title,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~figure_name="spectrum",\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~show=fftshow,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~print_success("FFT finished.")\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~return \{"segments": fft_results\}\par
\pard\sa120\par
\pard\ql\sb180\sa80\sl360\slmult1\f0\fs24\b 7. utils/FreqAnalysis.py\par
\pard\ql\li360\sa0\sb0\f2\fs16 """Sliding-window frequency summary metrics."""\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 import matplotlib.pyplot as plt\par
\pard\ql\li360\sa0\sb0\f2\fs16 import numpy as np\par
\pard\ql\li360\sa0\sb0\f2\fs16 from scipy.fft import fft\par
\pard\ql\li360\sa0\sb0\f2\fs16 from scipy.signal.windows import hann\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 from utils.ui import add_series, as_bool, finish_figure, make_plot_title, print_status, print_subsection, print_success, style_axes\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 def _moving_average(values, window_size):\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~"""Return a centered moving average for visualization-only trend overlays."""\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~if window_size <= 1 or len(values) < window_size:\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~return np.asarray(values, dtype=float)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~padded = np.pad(values, (window_size // 2, window_size - 1 - window_size // 2), mode="edge")\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~kernel = np.ones(window_size, dtype=float) / window_size\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~return np.convolve(padded, kernel, mode="valid")\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 def run_freq_analysis(dataset, data_title, config):\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~"""Compute sliding-window RMS, MPF, and MDF while plotting only RMS and MDF."""\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~fs = float(config["datainfo"]["Fs"])\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~seq_len = max(1, int(fs * float(config["analysis"].get("rms_time", 1.0))))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~seq_gap = max(1, int(fs * float(config["analysis"].get("rms_gap", 0.5))))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~display_config = config.get("display", \{\})\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~output_config = config.get("output", \{\})\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~show = as_bool(display_config.get("freq_analysis_show", False))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~save_figures = as_bool(output_config.get("save_figures", False))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~segment_labels = config["datainfo"].get("segment_labels", [])\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~trend_seconds = max(0.0, float(config["analysis"].get("mdf_trend_seconds", 5.0)))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~print_subsection("Frequency Summary")\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~print_status("Computing sliding-window EMG summary metrics (RMS, MPF, MDF).")\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~results = []\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~for idx, signal in enumerate(dataset):\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~label = segment_labels[idx] if idx < len(segment_labels) else f"segment_\{idx + 1\}"\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~signal = np.asarray(signal, dtype=float)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~if len(signal) < seq_len:\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~results.append(\{"label": label, "rms": [], "mpf_hz": [], "mdf_hz": [], "time_s": []\})\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~continue\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~window = hann(seq_len)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~freqs = np.arange(0, seq_len // 2) * fs / seq_len\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~mpf = []\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~mdf = []\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~rms = []\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~time_s = []\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~for start in range(0, len(signal) - seq_len + 1, seq_gap):\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~segment = signal[start : start + seq_len]\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~power = np.abs(fft(segment * window) / seq_len)[: len(freqs)] ** 2\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~power_sum = np.sum(power)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~if power_sum == 0:\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~power_sum = 1e-12\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~mpf.append(float(np.sum(freqs * power) / power_sum))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~cumulative_power = np.cumsum(power)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~mdf.append(float(freqs[np.argmin(np.abs(cumulative_power - 0.5 * cumulative_power[-1]))]))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~rms.append(float(np.sqrt(np.mean(np.abs(segment) ** 2))))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~time_s.append(start / fs)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~step_seconds = seq_gap / fs if fs else 0.0\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~trend_window = max(1, int(round(trend_seconds / step_seconds))) if step_seconds > 0 else 1\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~mdf_trend = _moving_average(np.asarray(mdf, dtype=float), trend_window)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~if show or save_figures:\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~# TODO: Visualization styling lives here so it can be tuned globally later.\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~fig, (ax_rms, ax_mdf) = plt.subplots(\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~2,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~1,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~figsize=(10.5, 7.2),\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~sharex=True,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~constrained_layout=True,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~gridspec_kw=\{"hspace": 0.18\},\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~fig.suptitle(make_plot_title(config, label, "RMS and MDF"), fontsize=13.0, fontweight="semibold")\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~add_series(ax_rms, time_s, rms, color="#6c5b7b", linewidth=1.9, fill=True)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~style_axes(ax_rms, "RMS", "", "RMS")\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~add_series(\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~ax_mdf,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~time_s,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~mdf,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~color="#a8a4b8",\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~linewidth=1.1,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~alpha=0.85,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~label="Raw MDF",\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~add_series(\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~ax_mdf,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~time_s,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~mdf_trend,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~color="#c8553d",\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~linewidth=2.2,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~label="Trend MDF",\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~style_axes(ax_mdf, "MDF", "Time (s)", "Frequency (Hz)")\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~ax_mdf.legend(loc="upper right", frameon=False)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~finish_figure(\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~fig,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~config=config,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~module_name="freq_analysis",\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~label=label,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~data_title=data_title,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~figure_name="rms_mdf",\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~show=show,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~layout="none",\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~results.append(\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\{\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~"label": label,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~"rms": rms,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~"mpf_hz": mpf,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~"mdf_hz": mdf,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~"mdf_trend_hz": mdf_trend.tolist(),\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~"time_s": time_s,\par
