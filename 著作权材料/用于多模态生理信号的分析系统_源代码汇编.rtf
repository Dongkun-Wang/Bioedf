\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~# STFT uses about a 0.5 s analysis window (power-of-two from Fs) with 50% overlap by default.\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~# This is a good compromise for EMG time-frequency visualization.\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~"stft_overlap": 0.5,\par
