\pard\ql\li360\sa0\sb0\f2\fs16 def run_band_analysis(dataset, data_title, config):\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~"""Compute EEG band-power metrics and derived concentration/relaxation indices."""\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~fs = float(config["datainfo"]["Fs"])\par
