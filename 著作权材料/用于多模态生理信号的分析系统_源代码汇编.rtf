\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~spectrum = spectrum[keep, :]\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~total_power = np.sum(spectrum, axis=0)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~total_power = np.where(total_power == 0, 1e-12, total_power)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
