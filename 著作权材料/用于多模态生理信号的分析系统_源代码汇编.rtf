\pard\ql\sb180\sa80\sl360\slmult1\f0\fs24\b 1. main.py\par
\pard\ql\li360\sa0\sb0\f2\fs16 from nm_config import nm_config\par
\pard\ql\li360\sa0\sb0\f2\fs16 from utils.Analysis import run_analysis\par
\pard\ql\li360\sa0\sb0\f2\fs16 from utils.LoadDataset import load_dataset\par
\pard\ql\li360\sa0\sb0\f2\fs16 from utils.Preprocess import preprocess_dataset\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 def main():\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~"""Run the end-to-end signal analysis pipeline."""\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~config = nm_config()\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~config["fileinfo"]["fullpath"] = "./data/\u21491?\u-32385?"\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~# Enable these lines when you want to inspect only part of a recording.\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~config["dataset"]["slice_enabled"] = True\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~config["dataset"]["slice_start"] = "17:17:10"\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~config["dataset"]["slice_end"] = "17:19:50"\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~dataset, config = load_dataset(config)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~filtered_dataset = preprocess_dataset(config, dataset)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~return run_analysis(filtered_dataset, "filtered_dataset", config)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 if __name__ == "__main__":\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~main()\par
\pard\sa120\par
