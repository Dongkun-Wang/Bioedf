\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~"bandstop",\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~config["preprocess"]["bsfreq"],\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~fs,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~config["preprocess"].get("bsfiltord", 4),\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~)\par
