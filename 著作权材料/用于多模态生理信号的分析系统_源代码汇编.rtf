\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~"bandpass",\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~config["preprocess"]["bpfreq"],\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~fs,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~config["preprocess"].get("bpfiltord", 4),\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~if as_bool(config["preprocess"].get("bsfilter", False)):\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~filtered_signal = _apply_filter(\par
