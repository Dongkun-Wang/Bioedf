\pard\ql\li360\sa0\sb0\f2\fs16 """Short-time Fourier transform analysis."""\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 import matplotlib.pyplot as plt\par
\pard\ql\li360\sa0\sb0\f2\fs16 import numpy as np\par
\pard\ql\li360\sa0\sb0\f2\fs16 from scipy.signal import spectrogram\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 from utils.ui import as_bool, finish_figure, make_plot_title, print_status, print_subsection, print_success, style_colorbar, style_heatmap\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 def run_stft(dataset, data_title, config):\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~"""Perform STFT spectrogram analysis and mandatory energy estimation."""\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~fs = float(config["datainfo"]["Fs"])\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~segment_labels = config["datainfo"].get("segment_labels", [])\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~display_config = config.get("display", \{\})\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~output_config = config.get("output", \{\})\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~stft_show = as_bool(display_config.get("stft_show", False))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~save_figures = as_bool(output_config.get("save_figures", False))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~stft_overlap = float(config["analysis"].get("stft_overlap", 0.5))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~calorie_show = as_bool(display_config.get("calorie_show", False))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~calorie_power_ratio = float(config["analysis"].get("calorie_power_ratio", 25))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~print_subsection("STFT")\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~print_status("Computing spectrograms and energy estimates.")\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~win_len = max(8, 2 ** int(np.floor(np.log2(fs))))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~noverlap = min(int(win_len * stft_overlap), win_len - 1)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~results = []\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~for idx, signal in enumerate(dataset):\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~label = segment_labels[idx] if idx < len(segment_labels) else f"segment_\{idx + 1\}"\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~signal = np.asarray(signal, dtype=float)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~freqs, times, spectrum = spectrogram(\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~signal,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~fs=fs,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~window="hann",\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~nperseg=win_len,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~noverlap=noverlap,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~nfft=win_len,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~valid_idx = freqs <= 250\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~freqs = freqs[valid_idx]\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~spectrum = spectrum[valid_idx, :]\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~rms = float(np.sqrt(np.mean(signal**2)))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~duration = len(signal) / fs\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~power_est = rms * calorie_power_ratio\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~kcal_est = (power_est * duration) / 4184\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~if calorie_show:\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~print_status(f"\{label\}: RMS=\{rms:.4f\}, estimated power=\{power_est:.2f\} W, calories~\{kcal_est:.4f\} kcal")\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~if stft_show or save_figures:\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~# TODO: Visualization styling lives here so it can be tuned globally later.\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~fig_spec, ax_spec = plt.subplots(figsize=(10.8, 4.8), constrained_layout=True)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~log_spectrum = 10 * np.log10(spectrum + 1e-12)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~vmin, vmax = np.percentile(log_spectrum, [5, 99.5])\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~image = ax_spec.pcolormesh(\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~times,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~freqs,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~log_spectrum,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~shading="auto",\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~cmap="magma",\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~vmin=vmin,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~vmax=vmax,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~colorbar = fig_spec.colorbar(image, ax=ax_spec, pad=0.02, aspect=28)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~style_colorbar(colorbar, "Power/Frequency (dB/Hz)")\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~style_heatmap(ax_spec, make_plot_title(config, label, "Spectrogram"), "Time (s)", "Frequency (Hz)")\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~finish_figure(\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~fig_spec,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~config=config,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~module_name="stft",\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~label=label,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~data_title=data_title,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~figure_name="spectrogram",\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~show=stft_show,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~layout="none",\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~results.append(\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\{\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~"label": label,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~"frequency_hz": freqs,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~"time_s": times,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~"spectrum": spectrum,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~"power_estimate_w": power_est,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~"calorie_estimate_kcal": kcal_est,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~\~\~\~\~\}\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~print_success("STFT finished.")\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~return \{"segments": results\}\par
