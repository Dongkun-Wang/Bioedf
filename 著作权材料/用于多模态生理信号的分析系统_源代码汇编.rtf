\pard\ql\li360\sa0\sb0\f2\fs16 def _write_signal_csv(path, start_dt, values):\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~"""Create a minimal headerless CSV test signal."""\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~rows = []\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~for index, value in enumerate(values):\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~timestamp = int((start_dt + timedelta(seconds=index)).timestamp() * 1000)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~rows.append([timestamp, index, value])\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~pd.DataFrame(rows).to_csv(path, header=False, index=False)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
