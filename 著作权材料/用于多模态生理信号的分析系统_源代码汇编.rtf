\pard\ql\li360\sa0\sb0\f2\fs16 def _build_analysis_config():\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~"""Return analysis parameter defaults."""\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~return \{\par
