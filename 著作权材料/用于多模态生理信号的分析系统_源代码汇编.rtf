\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~noverlap = min(int(win_len * 0.5), win_len - 1)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~freq_bands = \{\par
