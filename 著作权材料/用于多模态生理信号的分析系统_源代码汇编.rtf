\pard\ql\li360\sa0\sb0\f2\fs16 def _make_noisy_ecg(fs, duration_seconds, beat_times):\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~time_axis = np.arange(0, duration_seconds, 1 / fs)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~signal = 0.08 * np.sin(2 * np.pi * 0.35 * time_axis)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~signal += 0.04 * np.sin(2 * np.pi * 0.12 * time_axis + 0.5)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~for beat_time in beat_times:\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~signal += -1.8 * np.exp(-0.5 * ((time_axis - beat_time) / 0.018) ** 2)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~signal += 0.35 * np.exp(-0.5 * ((time_axis - (beat_time - 0.16)) / 0.04) ** 2)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~signal += 0.45 * np.exp(-0.5 * ((time_axis - (beat_time + 0.22)) / 0.07) ** 2)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~rng = np.random.default_rng(42)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~signal += 0.03 * rng.standard_normal(len(time_axis))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~return signal\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
