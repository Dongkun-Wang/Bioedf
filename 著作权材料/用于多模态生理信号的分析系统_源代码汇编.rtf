\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~save_csv = as_bool(output_config.get("save_band_metrics_csv", False))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~result_dir = config["fileinfo"].get("result_dir", "./result")\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~freq_limit = float(config["analysis"].get("band_freq_limit", 60))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
