\pard\ql\li360\sa0\sb0\f2\fs16 """Signal preprocessing helpers."""\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 import matplotlib.pyplot as plt\par
\pard\ql\li360\sa0\sb0\f2\fs16 import numpy as np\par
\pard\ql\li360\sa0\sb0\f2\fs16 from scipy.signal import butter, sosfilt\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 from utils.ui import add_series, as_bool, finish_figure, make_plot_title, print_kv, print_section, print_subsection, print_success, style_axes\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 def _validate_filter_config(freq, fs, name):\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~"""Validate the configured cutoff range for a digital filter."""\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~if freq is None:\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~raise ValueError(f"\{name\} frequency is not set. Load data and infer the signal profile first.")\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~if not isinstance(freq, (list, tuple)) or len(freq) != 2:\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~raise ValueError(f"\{name\} frequency must be a two-element list or tuple.")\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~low, high = float(freq[0]), float(freq[1])\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~nyquist = 0.5 * float(fs)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~if low <= 0 or high <= 0 or low >= high:\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~raise ValueError(f"Invalid \{name\} frequency range: \{freq\}")\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~if high >= nyquist:\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~raise ValueError(f"\{name\} high cutoff must be lower than the Nyquist frequency \{nyquist:.4f\} Hz.")\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 def _apply_filter(data, btype, freq, fs, order):\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~"""Apply a Butterworth filter in second-order sections form."""\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~_validate_filter_config(freq, fs, btype)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~normal_freq = np.asarray(freq, dtype=float) / (0.5 * float(fs))\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~sos = butter(int(order), normal_freq, btype=btype, output="sos")\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~return sosfilt(sos, data)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 def preprocess_dataset(config, dataset, show=None, saveon=None):\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~"""Filter each 1D segment according to the resolved preprocessing config."""\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~display_config = config.get("display", \{\})\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~output_config = config.get("output", \{\})\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~show = as_bool(display_config.get("preprocess_show", False) if show is None else show)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~saveon = as_bool(output_config.get("save_figures", False) if saveon is None else saveon)\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~fs = config["datainfo"]["Fs"]\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~segment_labels = config["datainfo"].get("segment_labels", [])\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~print_section("PREPROCESS")\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~print_subsection("Filter Setup")\par
\pard\ql\li360\sa0\sb0\f2\fs16 \par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~filters = [\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~("bpfilter", "bp", "Band-pass"),\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~("bsfilter", "bs", "Band-stop"),\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~]\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~for filter_field, filter_prefix, filter_name in filters:\par
