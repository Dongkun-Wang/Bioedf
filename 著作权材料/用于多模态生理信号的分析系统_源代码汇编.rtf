\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~# Derived metrics summarize where the spectrum is centered and how spread it is.\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~spectrum_sum = np.sum(spectrum, axis=0) + 1e-12\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~spectral_centroid = np.sum(freqs[:, None] * spectrum, axis=0) / spectrum_sum\par
