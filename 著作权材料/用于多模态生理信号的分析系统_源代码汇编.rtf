\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~"bsfreq": None,\par
\pard\ql\li360\sa0\sb0\f2\fs16 \~\~\~\~\~\~\~\~"bpfiltord": 4,\par
